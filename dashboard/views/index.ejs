<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dar Dzayer — Dashboard</title>
  <%- include('_style') %>
</head>
<body>
  <%- include('_nav', { page: 'home' }) %>
  <main>
    <p class="page-title">Bonjour 👋 — Aujourd'hui <%= new Date().toLocaleDateString('fr-DZ', { weekday: 'long', day: 'numeric', month: 'long' }) %></p>

    <div class="stats">
      <div class="stat accent">
        <div class="num"><%= stats.reservationsAujourdhui %></div>
        <div class="label">Réservations aujourd'hui</div>
      </div>
      <div class="stat <%= stats.messagesEnAttente > 0 ? 'alert' : '' %>">
        <div class="num"><%= stats.messagesEnAttente %></div>
        <div class="label">Messages en attente</div>
      </div>
      <div class="stat">
        <div class="num"><%= stats.totalReservations %></div>
        <div class="label">Total réservations</div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">📅 Réservations du jour</div>
      <% if (reservationsAujourdhui.length === 0) { %>
        <p class="empty">Aucune réservation pour aujourd'hui</p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>#</th><th>Client</th><th>Heure</th><th>Pers.</th><th>Table</th></tr>
          </thead>
          <tbody>
            <% reservationsAujourdhui.forEach(r => { %>
            <tr>
              <td style="color:#aaa">#<%= r.id %></td>
              <td>
                <strong><%= r.client_nom %></strong><br>
                <span style="color:#aaa;font-size:12px"><%= r.client_telephone.replace('@c.us','') %></span>
              </td>
              <td><%= r.heure_debut %> – <%= r.heure_fin %></td>
              <td><%= r.nombre_personnes %></td>
              <td><span class="badge badge-green"><%= r.table_id %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <div style="margin-top:12px"><a href="/reservations" style="font-size:13px;color:#c8a96e">Voir toutes les réservations →</a></div>
      <% } %>
    </div>

    <div class="card">
      <div class="card-title">💬 Messages en attente (derniers 5)</div>
      <% if (messagesEnAttente.length === 0) { %>
        <p class="empty">Aucun message en attente ✅</p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>Client</th><th>Message</th><th>Type</th><th>Date</th></tr>
          </thead>
          <tbody>
            <% messagesEnAttente.forEach(m => { %>
            <tr>
              <td style="white-space:nowrap"><%= m.telephone.replace('@c.us','') %></td>
              <td style="max-width:280px"><%= m.message %></td>
              <td><span class="raison-tag"><%= m.raison %></span></td>
              <td style="color:#aaa;font-size:12px"><%= new Date(m.created_at).toLocaleString('fr-DZ') %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <div style="margin-top:12px"><a href="/messages" style="font-size:13px;color:#c8a96e">Gérer les messages →</a></div>
      <% } %>
    </div>
  </main>
</body>
</html>
